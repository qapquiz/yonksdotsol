{
  "name": "yonksdotsol",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run fmt:check && npm run android:build",
    "dev": "expo start --clear --dev-client --reset-cache",
    "doctor": "npx -y expo-doctor@latest",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "web": "expo start --web"
  },
  "displayName": "Uniwind Mobile Kit Expo example",
  "description": "A template for building a Solana mobile app with Expo, React Native, Solana Kit, and Uniwind.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit",
    "uniwind",
    "tailwind"
  ],
  "main": "./index.js",
  "version": "1.1.0",
  "dependencies": {
    "@craftzdog/react-native-buffer": "^6.1.1",
    "@meteora-ag/dlmm": "^1.9.3",
    "@solana/kit": "^6.3.0",
    "@solana/web3.js": "^1.98.4",
    "@wallet-ui/react-native-kit": "^4.0.1",
    "buffer": "^6.0.3",
    "expo": "^55.0.4",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-insights": "~55.0.11",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "metcomet": "^0.1.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-quick-crypto": "^1.0.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^4.2.1",
    "uniwind": "^1.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
