{
  "name": "yonksdotsol",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build": "tsgo --noEmit && npm run android:build",
    "ci": "tsgo --noEmit && npm run lint:check && npm run fmt:check && npm run android:build",
    "dev": "expo start --clear --dev-client --reset-cache",
    "doctor": "npx -y expo-doctor@latest",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "displayName": "Uniwind Mobile Kit Expo example",
  "description": "A template for building a Solana mobile app with Expo, React Native, Solana Kit, and Uniwind.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit",
    "uniwind",
    "tailwind"
  ],
  "main": "./index.js",
